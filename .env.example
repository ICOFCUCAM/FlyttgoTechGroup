# Public site origin used by metadata, robots and sitemap.
NEXT_PUBLIC_SITE_URL=https://flyttgo.tech

# Supabase — /api/contact inserts into deployment_leads with the service role.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service-role-key-keep-server-only

# Resend — transactional email notifications from /api/contact.
# Sender must be a verified domain/address in Resend.
RESEND_API_KEY=re_yourkey
CONTACT_NOTIFICATION_FROM="FlyttGo Platform <platforms@flyttgo.tech>"
CONTACT_NOTIFICATION_TO=platforms@flyttgo.tech
