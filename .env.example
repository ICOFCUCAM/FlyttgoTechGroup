# =============================================================================
# FlyttGo Technologies Group — environment variables
# =============================================================================
#
# All variables are optional in dev — every feature degrades to a synthetic
# fallback when its env var is missing. Set them progressively as you turn
# on real backends.
#
# Naming convention:
#   NEXT_PUBLIC_* — bundled into the client. Safe to expose.
#   anything else — server-only. Must NEVER reach the browser.
#
# Copy this file to .env.local and fill in the values you want active.

# -----------------------------------------------------------------------------
# 1. Site origin (required for canonical URLs, sitemap, OG images)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://flyttgo.tech

# -----------------------------------------------------------------------------
# 2. Supabase — sandbox workspaces, AI artefact provenance, status feed,
#    auth, deployment leads, accounting flows
# -----------------------------------------------------------------------------
# FlyttgoTech project — bxjynfuzqhlirdozlgno
NEXT_PUBLIC_SUPABASE_URL=https://bxjynfuzqhlirdozlgno.supabase.co

# Modern publishable key (preferred). Safe to expose to the browser.
# Pull from Supabase dashboard → Project Settings → API → publishable.
NEXT_PUBLIC_SUPABASE_ANON_KEY=set-from-supabase-dashboard

# Service-role key. SERVER ONLY — bypasses RLS, has full DB access.
# Pull from Supabase dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=set-from-supabase-dashboard

# -----------------------------------------------------------------------------
# 3. Anthropic — powers /ask-flyttgo (CAIQ / RFP / proposal generators) and
#    Q&A in the AskFlyttGo modal. Without this key the route streams a
#    deterministic synthetic response instead — site keeps working at $0.
# -----------------------------------------------------------------------------
# Cost: ~$0.04-0.07 per artefact (Claude Sonnet 4.6 + prompt caching).
# Set a daily spend cap in Anthropic dashboard for cost-overrun protection.
ANTHROPIC_API_KEY=

# Override the default model if you want a cheaper / different one.
# Supported: claude-sonnet-4-6 (default) | claude-haiku-4-5-20251001 | claude-opus-4-7
# ANTHROPIC_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# 4. Resend — transactional email notifications from /api/contact
# -----------------------------------------------------------------------------
RESEND_API_KEY=
CONTACT_NOTIFICATION_FROM="FlyttGo Platform <platforms@flyttgo.tech>"
CONTACT_NOTIFICATION_TO=platforms@flyttgo.tech

# -----------------------------------------------------------------------------
# 5. Plausible / PostHog analytics (pick one — both wired, env-gated)
# -----------------------------------------------------------------------------
# Plausible: privacy-first, hosted at $9/mo or self-host free.
# Set the domain you registered with Plausible (typically your site host).
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=flyttgo.tech
# NEXT_PUBLIC_PLAUSIBLE_API_HOST=https://plausible.io

# PostHog: 1M events/mo free tier, full product analytics.
# NEXT_PUBLIC_POSTHOG_KEY=phc_yourkey
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# -----------------------------------------------------------------------------
# 6. Sentry — error monitoring (5k errors / mo free tier)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://abc...@oXXXX.ingest.sentry.io/YYYY
# SENTRY_AUTH_TOKEN=  # only needed for source-map upload at build
# SENTRY_ORG=flyttgo
# SENTRY_PROJECT=marketing

# -----------------------------------------------------------------------------
# 7. Uptime monitor → status_events table
# -----------------------------------------------------------------------------
# When configured, external monitors (UptimeRobot / Better Stack) hit
# /api/status/probe with this token to insert a status_events row.
# Generate any random 32+ char string.
STATUS_PROBE_TOKEN=
